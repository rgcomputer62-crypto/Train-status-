{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/train", "dest": "/api/train.js" },
    { "src": "/api/pnr", "dest": "/api/pnr.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
