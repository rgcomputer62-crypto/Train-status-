      <h1 style="font-family:'Syne',sans-serif;font-weight:800" class="text-3xl md:text-4xl tracking-tight">
        RailTrack <span style="color:#93c5fd">India</span>
      </h1>
    </div>
    <p class="text-blue-200 text-sm mt-1">Live Train Status &amp; PNR Tracker — Indian Railways</p>
  </div>
</header>

<!-- TABS -->
<div class="tab-bar">
  <div class="max-w-2xl mx-auto flex">
    <button class="tab-btn active flex-1 justify-center" id="tab-live" onclick="switchTab('live')">🚂 Live Train Status</button>
    <button class="tab-btn flex-1 justify-center" id="tab-pnr" onclick="switchTab('pnr')">🎫 PNR Status</button>
  </div>
</div>

<main class="max-w-2xl mx-auto px-4 pb-10">

  <!-- LIVE TRAIN PANEL -->
  <div id="panel-live">
    <div class="card search-card p-6 md:p-7 mt-5 mb-5">
      <label class="block text-xs font-semibold text-blue-400 uppercase tracking-widest mb-2" style="font-family:'Syne',sans-serif">Train Number daalo</label>
      <div class="flex gap-3">
        <input id="trainInput" type="text" inputmode="numeric" maxlength="5" placeholder="e.g. 12301"
          class="search-input flex-1 px-4 py-3 text-gray-800" autocomplete="off"
          onkeydown="if(event.key==='Enter')trackLive()"/>
        <button id="liveBtn" onclick="trackLive()" class="track-btn px-5 py-3 whitespace-nowrap">🔍 Track</button>
      </div>
      <p class="text-xs text-gray-400 mt-2">Example: 12301 (Howrah Rajdhani) · 12951 (Mumbai Rajdhani) · 11077 (Jhelum Express)</p>
    </div>
    <div id="liveResult"></div>
  </div>

  <!-- PNR PANEL -->
  <div id="panel-pnr" class="hidden">
    <div class="card search-card p-6 md:p-7 mt-5 mb-5">
      <label class="block text-xs font-semibold text-blue-400 uppercase tracking-widest mb-2" style="font-family:'Syne',sans-serif">PNR Number daalo</label>
      <div class="flex gap-3">
        <input id="pnrInput" type="text" inputmode="numeric" maxlength="10" placeholder="10-digit PNR e.g. 6461250996"
          class="search-input flex-1 px-4 py-3 text-gray-800" autocomplete="off"
          onkeydown="if(event.key==='Enter')trackPNR()"/>
        <button id="pnrBtn" onclick="trackPNR()" class="track-btn px-5 py-3 whitespace-nowrap">🎫 Check</button>
      </div>
      <p class="text-xs text-gray-400 mt-2">10-digit PNR number aapki ticket pe hota hai</p>
    </div>
    <div id="pnrResult"></div>
  </div>

</main>

<!--
