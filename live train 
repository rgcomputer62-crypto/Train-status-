<div class="ad-slot w-full h-14 md:h-20 px-4 my-2 max-w-3xl mx-auto">
  📢 Bottom Ad — Google AdSense Placeholder
</div>

<footer class="text-center text-xs text-gray-400 pb-6 px-4">
  Data via Indian Railway APIs on RapidAPI &nbsp;·&nbsp; Not affiliated with Indian Railways
</footer>

<script>
/* ════════════════════════════════════════════
 *  ✏️  STEP 1 — APNI RAPIDAPI KEY YAHAN DAALO
 *
 *  Dono APIs (Live Train + PNR) ke liye
 *  SAME key kaam karegi — ek hi jagah daalni hai!
 *
 *  Key kaise milegi:
 *  1. rapidapi.com pe login karo
 *  2. Koi bhi subscribed API open karo
 *  3. Code Snippets tab → "x-rapidapi-key" copy karo
 *  4. Neeche paste karo
 * ════════════════════════════════════════════ */
const RAPIDAPI_KEY = "fffc94f970msh79ac676b3ae557dp11f294jsn1d2eebd3a87f"; // ← SIRF YAHAN BADLE

// Hosts — change mat karna
const LIVE_HOST = "train-running-status-indian-railways.p.rapidapi.com";
const PNR_HOST  = "irctc-indian-railway-pnr-status.p.rapidapi.com";

/* ── Tab Switch ── */
function switchTab(tab) {
  document.getElementById("panel-live").classList.toggle("hidden", tab !== "live");
  document.getElementById("panel-pnr").classList.toggle("hidden",  tab !== "pnr");
  document.getElementById("tab-live").classList.toggle("active", tab === "live");
  document.getElementById("tab-pnr").classList.toggle("active",  tab === "pnr");
}

/* ══════════════════════════════
 *  LIVE TRAIN STATUS
 * ══════════════════════════════ */
async function trackLive() {
  const trainNo = document.getElementById("trainInput").value.trim();
  const btn  = document.getElementById("liveBtn");
  const area = document.getElementById("liveResult");

  if (!trainNo || !/^\d{4,5}$/.test(trainNo)) {
    showError(area,"Sahi 4-5 digit ka train number daalo.","⚠️"); return;
  }
  if (RAPIDAPI_KEY === "YOUR_RAPIDAPI_KEY_HERE") {
    showError(area,"API Key nahi daali! index.html mein <strong>RAPIDAPI_KEY</strong> update karo.","🔑"); return;
  }

  btn.disabled = true; btn.textContent = "Tracking…";
  area.innerHTML = loadingHTML("live train data");

  try {
    const url = `https://${LIVE_HOST}/trainman/${trainNo}`;

    const res = await fetch(url, {
      method:"GET",
      headers:{
        "Content-Type":"application/json",
        "x-rapidapi-host":LIVE_HOST,
        "x-rapidapi-key":RAPIDAPI_KEY
      }
    });

    if (!res.ok) throw new Error(res.status===401||res.status===403?"AUTH":res.status===404?"NOT_FOUND":"ERR");
    const json = await res.json();
    if (json?.body?.status===false||json?.status===false) throw new Error("NOT_FOUND");
    renderLive(area, json?.body||json, trainNo);

  } catch(e) {
    if (e.message==="NOT_FOUND") showError(area,`Train <strong>${trainNo}</strong> nahi mila. Number dobara check karo.`,"🚫");
    else if (e.message==="AUTH") showError(area,"API Key galat hai ya subscription expired. RapidAPI check karo.","🔑");
    else showError(area,"Live data nahi mila. Internet ya API check karo aur dobara try karo.","📡");
  } finally {
    btn.disabled=false; btn.textContent="🔍 Track";
  }
}

function renderLive(area, data, trainNo) {
  const train    = data?.train_info?.[0]||data?.data||data?.train||data||{};
  const name     = train.train_name||data?.train_name||"Train "+trainNo;
  const curStn   = train.current_station||data?.current_station||{};
  const nxtStn   = train.next_station||data?.next_station||{};
  const delay    = parseInt(train.delay??data?.delay??0,10);
  const updated  = train.last_updated||data?.last_updated||new Date().toISOString();
  const stations = data?.stations||train.route||train.stations||[];
  const runDate  = train.start_date||data?.start_date||"";

  const dBadge = badgeDelay(delay);

  let tlHTML = "";
  if (stations.length > 0) {
    tlHTML = `<p class="sec-title">Station Timeline</p><div class="timeline">`;
    stations.forEach(s => {
      const sn   = s.station_name||s.name||"Station";
      const sc   = s.station_code||s.code||"";
      const sd   = parseInt(s.delay??0,10);
      const sa   = s.scheduled_arrival||s.arrival||"";
      const aa   = s.actual_arrival||"";
      const isCur= s.is_current_station||s.isCurrent||false;
      const isPas= s.has_passed||s.hasPassed||false;
      const dot  = isPas?"passed":isCur?"current":"upcoming";
      const card = isCur?"current-card":isPas?"":"upcoming-card";
      tlHTML += `
        <div class="tl-item">
          <div class="tl-dot ${dot}"></div>
          <div class="tl-card ${card}">
            <div class="flex flex-wrap items-center gap-2">
              <span style="font-family:'Syne',sans-serif;font-weight:700" class="text-blue-900 text-sm">${escH(sn)}</span>
              ${sc?`<span class="train-tag">${escH(sc)}</span>`:""}
              ${isCur?`<span class="badge badge-info">🚉 YAHAN HAI</span>${dBadge}`:""}
            </div>
            <div class="flex flex-wrap gap-3 mt-1 text-xs text-gray-500">
              ${sa?`<span>🕐 Schedule: <b>${escH(sa)}</b></span>`:""}
              ${aa?`<span>✅ Actual: <b>${escH(aa)}</b></span>`:""}
              ${sd>0?`<span style="color:var(--danger)">⏱ +${sd} min</span>`:""}
            </div>
          </div>
        </div>`;
    });
    tlHTML += `</div>`;
  } else {
    tlHTML = `<p class="sec-title">Live Stations</p><div class="timeline">
      <div class="tl-item"><div class="tl-dot current"></div>
        <div class="tl-card current-card">
          <div class="flex flex-wrap items-center gap-2">
            <span style="font-family:'Syne',sans-serif;font-weight:700" class="text-blue-900 text-sm">${escH(curStn.station_name||curStn.name||"—")}</span>
            ${curStn.station_code?`<span class="train-tag">${escH(curStn.station_code)}</span>`:""}
            <span class="badge badge-info">🚉 CURRENT</span>${dBadge}
          </div>
        </div>
      </div>
      ${(nxtStn.station_name||nxtStn.name)?`
      <div class="tl-item"><div class="tl-dot upcoming"></div>
        <div class="tl-card upcoming-card">
          <div class="flex flex-wrap items-center gap-2">
            <span style="font-family:'Syne',sans-serif;font-weight:700" class="text-blue-900 text-sm">${escH(nxtStn.station_name||nxtStn.name)}</span>
            ${nxtStn.station_code?`<span class="train-tag">${escH(nxtStn.station_code)}</span>`:""}
            <span class="badge badge-info" style="background:#eff6ff">⏭ NEXT STOP</span>
          </div>
        </div>
      </div>`:""}
    </div>`;
  }

  area.innerHTML = `
    <div class="card p-6 slide-up">
      <div class="flex flex-wrap items-start justify-between gap-3 mb-4">
        <div>
          <p class="text-xs text-blue-400 font-semibold uppercase tracking-widest mb-0.5">Live Train Status</p>
          <h2 style="font-family:'Syne',sans-serif;font-weight:800" class="text-xl text-blue-900">${escH(name)}</h2>
          ${runDate?`<p class="text-xs text-gray-400 mt-0.5">Run Date: ${escH(runDate)}</p>`:""}
        </div>
        <button onclick="trackLive()" class="text-xs px-4 py-2 rounded-lg border border-blue-200 text-blue-500 hover:bg-blue-50 transition" style="font-family:'Syne',sans-serif;font-weight:600">↻ Refresh</button>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-5">
        <div class="stat-chip"><span class="label">Train No.</span><span class="value">${escH(trainNo)}</span></div>
        <div class="stat-chip"><span class="label">Delay</span><span class="value" style="color:${delay===0?"var(--success)":delay<=15?"var(--warn)":"var(--danger)"}">${delay===0?"On Time":"+"+delay+" min"}</span></div>
        <div class="stat-chip"><span class="label">Current Stn</span><span class="value text-sm">${escH(curStn.station_name||curStn.name||"—")}</span></div>
        <div class="stat-chip"><span class="label">Updated</span><span class="value text-sm">${fmtTime(updated)}</span></div>
      </div>
      ${tlHTML}
    </div>`;
}

/* ══════════════════════════════
 *  PNR STATUS
 * ══════════════════════════════ */
async function trackPNR() {
  const pnr  = document.getElementById("pnrInput").value.trim();
  const btn  = document.getElementById("pnrBtn");
  const area = document.getElementById("pnrResult");

  if (!pnr || !/^\d{10}$/.test(pnr)) {
    showError(area,"Sahi 10-digit PNR number daalo.","⚠️"); return;
  }
  if (RAPIDAPI_KEY === "YOUR_RAPIDAPI_KEY_HERE") {
    showError(area,"API Key nahi daali! index.html mein <strong>RAPIDAPI_KEY</strong> update karo.","🔑"); return;
  }

  btn.disabled=true; btn.textContent="Checking…";
  area.innerHTML = loadingHTML("PNR status");

  try {
    const url = `https://${PNR_HOST}/getPNRStatus/${pnr}`;
    const res = await fetch(url, {
      method:"GET",
      headers:{
        "Content-Type":"application/json",
        "X-RapidAPI-Host":PNR_HOST,
        "X-RapidAPI-Key":RAPIDAPI_KEY
      }
    });

    if (!res.ok) throw new Error(res.status===401||res.status===403?"AUTH":res.status===404?"NOT_FOUND":"ERR");
    const json = await res.json();
    if (!json || json?.StatusCode==="01" || json?.pnrErrorMessage) throw new Error("NOT_FOUND");
    renderPNR(area, json, pnr);

  } catch(e) {
    if (e.message==="NOT_FOUND") showError(area,`PNR <strong>${pnr}</strong> nahi mila. Number check karo ya ticket purani ho.`,"🎫");
    else if (e.message==="AUTH") showError(area,"API Key galat hai ya PNR API subscribe nahi ki. RapidAPI check karo.","🔑");
    else showError(area,"PNR data nahi mila. Internet ya API check karo.","📡");
  } finally {
    btn.disabled=false; btn.textContent="🎫 Check";
  }
}

function renderPNR(area, d, pnr) {
  const trainNo   = d.TrainNo||d.train_number||d.trainNumber||"—";
  const trainName = d.TrainName||d.train_name||d.trainName||"—";
  const from      = d.BoardingStationName||d.From||d.boardingStation||d.source||"—";
  const to        = d.DestinationStationName||d.To||d.destination||"—";
  const cls       = d.Class||d.class||d.travelClass||"—";
  const doj       = d.DateOfJourney||d.doj||d.journeyDate||"—";
  const quota     = d.Quota||d.quota||"—";
  const chart     = d.ChartPrepared||d.chart_prepared||false;
  const pax       = d.PassengerList||d.passengers||d.PassengerStatus||[];

  let paxHTML = "";
  if (pax.length > 0) {
    paxHTML = `<p class="sec-title mt-4">Passengers (${pax.length})</p>`;
    pax.forEach((p,i) => {
      const bS  = p.BookingStatus||p.bookingStatus||p.CurrentStatus||"—";
      const cS  = p.CurrentStatus||p.currentStatus||bS;
      const coach= p.CoachPosition||p.coachPosition||p.coach||"";
      const seat = p.BerthPosition||p.berthPosition||p.seat||"";
      const conf = /CNF|CONFIRMED|WL 0/i.test(cS);
      const wl   = /WL|WAITLIST/i.test(cS);
      const rac  = /RAC/i.test(cS);
      paxHTML += `
        <div class="pax-row">
          <div class="flex items-center gap-3">
            <div class="pax-num">${i+1}</div>
            <div>
              <div class="text-sm font-semibold text-blue-900" style="font-family:'Syne',sans-serif">Passenger ${i+1}</div>
              <div class="text-xs text-gray-500">Booking: ${escH(bS)}</div>
            </div>
          </div>
          <div class="flex flex-col items-end gap-1">
            <span class="badge ${conf?"badge-success":wl?"badge-danger":rac?"badge-warn":"badge-info"}">${escH(cS)}</span>
            ${coach||seat?`<span class="text-xs text-gray-400">${coach?escH(coach)+" ":""}${seat?escH(seat):""}</span>`:""}
          </div>
        </div>`;
    });
  } else {
    paxHTML = `<p class="text-xs text-gray-400 mt-3 text-center">Passenger details API response mein nahi hain.</p>`;
  }

  area.innerHTML = `
    <div class="card p-6 slide-up">
      <div class="flex flex-wrap items-start justify-between gap-3 mb-4">
        <div>
          <p class="text-xs text-blue-400 font-semibold uppercase tracking-widest mb-0.5">PNR Status</p>
          <h2 style="font-family:'Syne',sans-serif;font-weight:800" class="text-xl text-blue-900">${escH(trainName)}</h2>
          <div class="flex items-center gap-2 mt-1">
            <span class="train-tag">${escH(trainNo)}</span>
            ${chart
              ?`<span class="badge badge-success">✔ Chart Taiyaar</span>`
              :`<span class="badge badge-warn">⏳ Chart Pending</span>`}
          </div>
        </div>
        <button onclick="trackPNR()" class="text-xs px-4 py-2 rounded-lg border border-blue-200 text-blue-500 hover:bg-blue-50 transition" style="font-family:'Syne',sans-serif;font-weight:600">↻ Refresh</button>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-2">
        <div class="stat-chip"><span class="label">PNR</span><span class="value text-sm">${escH(pnr)}</span></div>
        <div class="stat-chip"><span class="label">Journey Date</span><span class="value text-sm">${escH(doj)}</span></div>
        <div class="stat-chip"><span class="label">Class</span><span class="value">${escH(cls)}</span></div>
        <div class="stat-chip"><span class="label">From</span><span class="value text-sm">${escH(from)}</span></div>
        <div class="stat-chip"><span class="label">To</span><span class="value text-sm">${escH(to)}</span></div>
        <div class="stat-chip"><span class="label">Quota</span><span class="value text-sm">${escH(quota)}</span></div>
      </div>
      ${paxHTML}
    </div>`;
}

/* ── Helpers ── */
function badgeDelay(d) {
  if (d===0) return `<span class="badge badge-success">✔ On Time</span>`;
  if (d<=15)  return `<span class="badge badge-warn">⏱ +${d} min</span>`;
  return `<span class="badge badge-danger">⚠ +${d} min late</span>`;
}
function fmtTime(iso) {
  try {
    const d=new Date(iso); if(isNaN(d))return iso;
    return d.toLocaleTimeString("en-IN",{hour:"2-digit",minute:"2-digit"})
      +", "+d.toLocaleDateString("en-IN",{day:"numeric",month:"short"});
  } catch{return iso}
}
function escH(s) {
  return String(s??"").replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;");
}
function loadingHTML(what) {
  return `<div class="card p-8 text-center slide-up">
    <div class="loading-dots mb-3"><span></span><span></span><span></span></div>
    <p class="text-blue-400 font-semibold text-sm" style="font-family:'Syne',sans-serif">Fetching ${what}…</p>
  </div>`;
}
function showError(area, msg, icon="❌") {
  area.innerHTML=`<div class="error-card p-6 text-center slide-up">
    <div class="text-4xl mb-3">${icon}</div>
    <h3 style="font-family:'Syne',sans-serif;font-weight:700" class="text-red-700 text-lg mb-1">Kuch galat hua</h3>
    <p class="text-red-500 text-sm leading-relaxed">${msg}</p>
  </div>`;
}
</script>
</body>
</html>
