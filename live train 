<!-- HEADER -->
<header class="header-bar px-4 py-7 md:py-10 text-white text-center relative z-10">
  <div class="max-w-2xl mx-auto">
    <div class="flex items-center justify-center gap-3 mb-1">
      <svg class="w-9 h-9 opacity-90" viewBox="0 0 48 48" fill="none">
        <rect x="6" y="14" width="36" height="22" rx="5" fill="white" fill-opacity="0.15" stroke="white" stroke-width="2"/>
        <rect x="10" y="18" width="12" height="8" rx="2" fill="white" fill-opacity="0.3"/>
        <rect x="26" y="18" width="12" height="8" rx="2" fill="white" fill-opacity="0.3"/>
        <circle cx="14" cy="38" r="4" fill="white" fill-opacity="0.5" stroke="white" stroke-width="2"/>
        <circle cx="34" cy="38" r="4" fill="white" fill-opacity="0.5" stroke="white" stroke-width="2"/>
        <line x1="6" y1="28" x2="42" y2="28" stroke="white" stroke-width="1.5" stroke-opacity="0.4"/>
        <line x1="24" y1="14" x2="24" y2="36" stroke="white" stroke-width="1.5" stroke-opacity="0.3"/>
