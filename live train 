<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>RailTrack India — Live Train & PNR Status</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --blue-deep:#0a2463; --blue-mid:#1e4fcf; --blue-bright:#3b82f6;
      --blue-light:#dbeafe; --success:#10b981; --danger:#ef4444; --warn:#f59e0b;
    }
    *{box-sizing:border-box}
    body{font-family:'DM Sans',sans-serif;background:#f0f6ff;min-height:100vh}
    h1,h2,h3{font-family:'Syne',sans-serif}

    .header-bar{background:linear-gradient(135deg,#0a2463 0%,#1a3a8f 60%,#1e4fcf 100%);position:relative;overflow:hidden}
    .header-bar::before{content:'';position:absolute;top:-60px;right:-80px;width:320px;height:320px;background:rgba(255,255,255,0.04);border-radius:50%}

    .tab-bar{background:#fff;border-bottom:2px solid #e0eaff;position:sticky;top:0;z-index:50;box-shadow:0 2px 12px rgba(10,36,99,0.07)}
    .tab-btn{font-family:'Syne',sans-serif;font-weight:700;font-size:0.88rem;letter-spacing:0.04em;padding:14px 20px;border:none;background:none;cursor:pointer;color:#94a3b8;border-bottom:3px solid transparent;transition:color .2s,border-color .2s;display:flex;align-items:center;gap:8px}
    .tab-btn.active{color:var(--blue-mid);border-bottom-color:var(--blue-mid)}
    .tab-btn:hover:not(.active){color:var(--blue-deep)}

    .card{background:#fff;border-radius:20px;box-shadow:0 4px 24px rgba(10,36,99,0.09)}
    .search-card{box-shadow:0 8px 40px rgba(10,36,99,0.13)}

    .search-input{border:2px solid #dbeafe;border-radius:12px;font-family:'Syne',sans-serif;font-size:1.05rem;letter-spacing:0.04em;outline:none;transition:border-color .2s,box-shadow .2s}
    .search-input:focus{border-color:var(--blue-bright);box-shadow:0 0 0 4px rgba(59,130,246,0.12)}

    .track-btn{background:linear-gradient(135deg,var(--blue-mid),var(--blue-bright));color:#fff;border-radius:12px;font-family:'Syne',sans-serif;font-weight:700;font-size:0.95rem;letter-spacing:0.04em;border:none;cursor:pointer;transition:transform .15s,box-shadow .15s,opacity .15s;box-shadow:0 4px 18px rgba(30,79,207,0.35)}
    .track-btn:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(30,79,207,0.4)}
    .track-btn:active{transform:translateY(0)}
    .track-btn:disabled{opacity:.65;cursor:not-allowed;transform:none}

    .ad-slot{background:repeating-linear-gradient(45deg,#e0eaff 0,#e0eaff 10px,#f0f6ff 10px,#f0f6ff 20px);border:2px dashed #93c5fd;border-radius:12px;display:flex;align-items:center;justify-content:center;color:#6b90c8;font-family:'Syne',sans-serif;font-size:.78rem;font-weight:600;letter-spacing:.08em;text-transform:uppercase}

    .badge{display:inline-flex;align-items:center;gap:5px;padding:3px 10px;border-radius:999px;font-family:'Syne',sans-serif;font-weight:700;font-size:.7rem;letter-spacing:.06em;text-transform:uppercase}
    .badge-success{background:#d1fae5;color:#065f46}
    .badge-warn{background:#fef3c7;color:#92400e}
    .badge-danger{background:#fee2e2;color:#991b1b}
    .badge-info{background:#dbeafe;color:#1e40af}

    .timeline{position:relative;padding-left:36px}
    .timeline::before{content:'';position:absolute;left:10px;top:12px;bottom:12px;width:3px;background:linear-gradient(to bottom,var(--blue-mid),#bfdbfe);border-radius:4px}
    .tl-item{position:relative}
    .tl-dot{position:absolute;left:-30px;top:14px;width:16px;height:16px;border-radius:50%;border:3px solid #fff;box-shadow:0 0 0 2px var(--blue-mid);z-index:1}
    .tl-dot.current{background:var(--blue-mid);animation:pulse 1.5s infinite}
    .tl-dot.passed{background:var(--success);box-shadow:0 0 0 2px var(--success)}
    .tl-dot.upcoming{background:#fff;box-shadow:0 0 0 2px #93c5fd}
    @keyframes pulse{0%,100%{box-shadow:0 0 0 4px rgba(30,79,207,0.25)}50%{box-shadow:0 0 0 8px rgba(30,79,207,0.08)}}

    .tl-card{background:#f8faff;border:1.5px solid #e0eaff;border-radius:14px;padding:12px 14px;margin-bottom:10px}
    .tl-card.current-card{background:linear-gradient(135deg,#eef4ff,#dbeafe);border-color:var(--blue-bright)}
    .tl-card.upcoming-card{border-color:#bfdbfe}

    .stat-chip{background:#f0f6ff;border:1.5px solid #dbeafe;border-radius:12px;padding:11px 14px;display:flex;flex-direction:column;gap:2px}
    .stat-chip .label{font-size:.65rem;text-transform:uppercase;letter-spacing:.08em;color:#6b90c8;font-weight:600}
    .stat-chip .value{font-family:'Syne',sans-serif;font-size:.95rem;font-weight:700;color:var(--blue-deep)}

    .pax-row{display:flex;align-items:center;justify-content:space-between;padding:10px 14px;border-radius:12px;background:#f8faff;border:1.5px solid #e0eaff;margin-bottom:8px}
    .pax-num{width:28px;height:28px;border-radius:50%;background:var(--blue-light);color:var(--blue-deep);font-family:'Syne',sans-serif;font-weight:800;font-size:.8rem;display:flex;align-items:center;justify-content:center;flex-shrink:0}

    .train-tag{background:var(--blue-light);color:var(--blue-deep);font-family:'Syne',sans-serif;font-weight:800;border-radius:8px;padding:2px 10px;font-size:.8rem;letter-spacing:.07em}

    .slide-up{animation:slideUp .4s cubic-bezier(.22,1,.36,1)}
    @keyframes slideUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}

    .loading-dots span{display:inline-block;width:9px;height:9px;border-radius:50%;background:var(--blue-bright);margin:0 3px;animation:dotB 1.1s infinite ease-in-out}
    .loading-dots span:nth-child(2){animation-delay:.18s}
    .loading-dots span:nth-child(3){animation-delay:.36s}
    @keyframes dotB{0%,80%,100%{transform:scale(.7);opacity:.5}40%{transform:scale(1);opacity:1}}

    .error-card{background:#fff5f5;border:2px solid #fecaca;border-radius:16px}
    .sec-title{font-family:'Syne',sans-serif;font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:#6b90c8;margin-bottom:10px}

    ::-webkit-scrollbar{width:6px}
    ::-webkit-scrollbar-track{background:#f0f6ff}
    ::-webkit-scrollbar-thumb{background:#93c5fd;border-radius:4px}
  </style>
</head>
<body>

